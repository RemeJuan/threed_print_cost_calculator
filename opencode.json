{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "firebase": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firebase-tools@latest",
        "mcp",
        "--only",
        "core,crashlytics"
      ]
    },
    "dart-mcp-server": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server"
      ],
      "enabled": true,
      "environment": {}
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": true
    }
  }
}