default_platform :ios

require "deliver"
require "fileutils"
require "tmpdir"

################################################################
# Helper: validate required env vars are set
################################################################
def check_ios_creds
  required = %w[APP_STORE_CONNECT_ISSUER_ID APP_STORE_CONNECT_KEY_IDENTIFIER APP_STORE_CONNECT_PRIVATE_KEY]
  missing = required.select { |v| ENV[v].nil? || ENV[v].empty? }
  UI.user_error!("Missing iOS credentials: #{missing.join(', ')}") unless missing.empty?
  UI.success "iOS credentials: OK"
end

def check_android_creds
  UI.user_error!("Missing SUPPLY_JSON_KEY_DATA") if ENV["SUPPLY_JSON_KEY_DATA"].nil? || ENV["SUPPLY_JSON_KEY_DATA"].empty?
  require "json"
  data = JSON.parse(ENV["SUPPLY_JSON_KEY_DATA"])
  UI.success "Android credentials: OK (project: #{data['project_id']})"
rescue JSON::ParserError => e
  UI.user_error!("SUPPLY_JSON_KEY_DATA is not valid JSON: #{e.message}")
end

def screenshots_output_dir
  File.expand_path("screenshots/output", __dir__)
end

def screenshot_upload_order
  order_path = File.expand_path("screenshots/upload_order.txt", __dir__)
  File.readlines(order_path, chomp: true).map(&:strip).reject(&:empty?)
end

def ios_screenshots_dir
  File.join(screenshots_output_dir, "ios")
end

def stage_ios_screenshots_upload
  source_dir = ios_screenshots_dir
  UI.user_error!("Missing iOS screenshots output: #{source_dir}") unless Dir.exist?(source_dir)

  staging_dir = Dir.mktmpdir("ios-screenshots-upload-")

  Dir.children(source_dir).sort.each do |locale|
    locale_src = File.join(source_dir, locale)
    next unless File.directory?(locale_src)

    locale_dst = File.join(staging_dir, locale)
    FileUtils.mkdir_p(locale_dst)

    by_asset = Dir.glob(File.join(locale_src, "*.png")).each_with_object({}) do |path, memo|
      memo[File.basename(path, ".png")] = path
    end

    ordered_paths = screenshot_upload_order.filter_map { |asset| by_asset[asset] }
    remaining_paths = by_asset.values - ordered_paths

    (ordered_paths + remaining_paths.sort).each_with_index do |path, idx|
      dst_name = format("%02d_%s", idx + 1, File.basename(path))
      FileUtils.cp(path, File.join(locale_dst, dst_name))
    end
  end

  staging_dir
end

def android_screenshots_dir
  File.join(screenshots_output_dir, "android")
end

def stage_android_screenshots_upload
  source_dir = android_screenshots_dir
  UI.user_error!("Missing Android screenshots output: #{source_dir}") unless Dir.exist?(source_dir)

  staging_dir = Dir.mktmpdir("android-screenshots-upload-")
  copy_dir = File.expand_path("screenshots/copy", __dir__)
  configured_locales = Dir.glob(File.join(copy_dir, "*.yaml")).map do |path|
    File.basename(path, ".yaml")
  end
  locales = Dir.children(source_dir).sort.select do |entry|
    File.directory?(File.join(source_dir, entry)) && configured_locales.include?(entry)
  end
  skipped_locales = Dir.children(source_dir).sort.select do |entry|
    File.directory?(File.join(source_dir, entry)) && !configured_locales.include?(entry)
  end
  screenshot_types = %w[phoneScreenshots sevenInchScreenshots tenInchScreenshots]
  locale_map = {
    "it" => "it-IT"
  }

  skipped_locales.each do |locale|
    UI.important("Skipping stale Android screenshot locale '#{locale}' (no matching copy YAML)")
  end

  locales.each do |locale|
    play_locale = locale_map.fetch(locale, locale)
    locale_src = File.join(source_dir, locale)
    locale_dst = File.join(staging_dir, play_locale, "images")
    FileUtils.mkdir_p(locale_dst)

    by_asset = Dir.glob(File.join(locale_src, "*.png")).each_with_object({}) do |path, memo|
      memo[File.basename(path, ".png")] = path
    end

    ordered_paths = screenshot_upload_order.filter_map { |asset| by_asset[asset] }
    remaining_paths = by_asset.values - ordered_paths
    ordered_upload_paths = ordered_paths + remaining_paths.sort

    screenshot_types.each do |type|
      type_dir = File.join(locale_dst, type)
      FileUtils.mkdir_p(type_dir)
      ordered_upload_paths.each_with_index do |path, idx|
        dst_name = format("%02d_%s", idx + 1, File.basename(path))
        FileUtils.cp(path, File.join(type_dir, dst_name))
      end
    end
  end

  staging_dir
end

def replace_ios_screenshots(screenshots_path)
  app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
  UI.user_error!("Missing iOS app identifier in Appfile") if app_identifier.to_s.empty?

  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**api_key)

  app = Spaceship::ConnectAPI::App.find(app_identifier)
  UI.user_error!("Could not find app with app identifier '#{app_identifier}'") unless app

  version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
  UI.user_error!("Could not find a version to edit for app '#{app.name}'") unless version

  localizations = version.get_app_store_version_localizations
  screenshots = Deliver::Loader.load_app_screenshots(screenshots_path, true)
  screenshots_per_language = screenshots.group_by(&:language)
  iterator = Deliver::AppScreenshotIterator.new(localizations)
  processed_sets = {}

  iterator.each_local_screenshot(screenshots_per_language) do |localization, app_screenshot_set, screenshot, index|
    unless processed_sets[app_screenshot_set.id]
      UI.important("Replacing screenshots for #{localization.locale} #{app_screenshot_set.screenshot_display_type}")
      (app_screenshot_set.app_screenshots || []).each(&:delete!)
      processed_sets[app_screenshot_set.id] = true
    end

    UI.message("Uploading #{File.basename(screenshot.path)} to #{localization.locale} #{app_screenshot_set.screenshot_display_type}")
    app_screenshot_set.upload_screenshot(path: screenshot.path, wait_for_processing: true, position: index)
    UI.message("Uploaded #{File.basename(screenshot.path)}")
  end

  UI.success("Successfully uploaded screenshots to App Store Connect")
end

platform :ios do
  ################################################################
  # Build API key from env vars for deliver
  ################################################################
  def api_key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_IDENTIFIER"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_PRIVATE_KEY"],
      is_key_content_base64: false
    )
  end

  ################################################################
  # Check iOS credentials without touching App Store Connect
  ################################################################
  desc "Verify iOS credentials are valid and present"
  lane :metadata_check do
    check_ios_creds
    api_key
    UI.success "iOS credentials OK — try ios metadata_pull for a connectivity test"
  end

  ################################################################
  # Pull current metadata from App Store Connect via CLI
  ################################################################
  desc "Pull iOS metadata from App Store Connect"
  lane :metadata_pull do
    check_ios_creds
    api_key_path = File.expand_path("../.asc_api_key.json", __dir__)
    api_key_data = {
      key_id: ENV["APP_STORE_CONNECT_KEY_IDENTIFIER"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key: ENV["APP_STORE_CONNECT_PRIVATE_KEY"],
      in_house: false
    }
    metadata_dir = File.expand_path("metadata/ios", __dir__)
    File.write(api_key_path, JSON.generate(api_key_data))
    sh("bundle", "exec", "fastlane", "deliver", "download_metadata",
       "--force",
       "--metadata_path", metadata_dir,
       "--api_key_path", api_key_path)
    File.delete(api_key_path)
    UI.success "iOS metadata downloaded"
  end

  ################################################################
  # Push local metadata changes to App Store Connect.
  #
  # en-GB is the default ASC locale.
  # Repo source lives in metadata/ios/en-GB and is uploaded as the
  # real `en-GB` locale directory.
  # All 6 non-default locales pushed as subdirectories.
  ################################################################
  desc "Push metadata to App Store Connect (no binary, no screenshots)"
  lane :metadata_push do |options|
    check_ios_creds
    ios_push_locales = %w[de-DE pt-BR es-ES fr-FR it ja]
    check_no_untranslated(
      File.expand_path("metadata/ios", __dir__),
      %w[en-GB de-DE pt-BR es-ES fr-FR it ja],
      %w[name.txt subtitle.txt description.txt keywords.txt release_notes.txt]
    )
    key = api_key
    metadata_dir = File.expand_path("metadata/ios", __dir__)
    push_dir = File.expand_path("metadata/ios_push", __dir__)
    FileUtils.rm_rf(push_dir) if Dir.exist?(push_dir)
    FileUtils.mkdir_p(push_dir)
    # Primary ASC metadata lives in the real en-GB locale folder.
    en_gb_src = File.join(metadata_dir, "en-GB")
    en_gb_dst = File.join(push_dir, "en-GB")
    if Dir.exist?(en_gb_src)
      FileUtils.mkdir_p(en_gb_dst)
      Dir.glob(File.join(en_gb_src, "*")).each do |f|
        FileUtils.cp(f, File.join(en_gb_dst, File.basename(f)))
      end
      default_name = File.join(en_gb_dst, "name.txt")
      FileUtils.rm(default_name) if File.exist?(default_name)
    end
    # Copy non-default locale subdirectories
    ios_push_locales.each do |locale|
      src = File.join(metadata_dir, locale)
      next unless Dir.exist?(src)
      FileUtils.cp_r(src, File.join(push_dir, locale))
      # Remove name.txt from locale dirs — ASC auto-inherits from default locale.
      # Pushing it triggers name-conflict errors for locales added after release.
      # URL/privacy/promotional files are also excluded (non-localizable ASC fields).
      name_file = File.join(push_dir, locale, "name.txt")
      FileUtils.rm(name_file) if File.exist?(name_file)
    end
    # Copy top-level files shared across all locales
    Dir.glob(File.join(metadata_dir, "*.txt")).each do |f|
      FileUtils.cp(f, File.join(push_dir, File.basename(f)))
    end
    begin
      deliver(
        api_key: key,
        skip_metadata: false,
        skip_binary_upload: true,
        skip_screenshots: true,
        force: true,
        submit_for_review: false,
        automatic_release: false,
        phased_release: false,
        reject_if_possible: false,
        overwrite_screenshots: false,
        metadata_path: push_dir,
        ignore_language_directory_validation: true,
        run_precheck_before_submit: false
      )
    ensure
      FileUtils.rm_rf(push_dir) if Dir.exist?(push_dir)
    end
  end

  ################################################################
  # Push release notes only to App Store Connect
  #
  # Useful for patch releases where description/keywords/subtitle stay
  # unchanged and only What's New text needs updating.
  ################################################################
  desc "Push iOS release notes only to App Store Connect (no binary, no screenshots)"
  lane :release_notes_push do
    check_ios_creds
    ios_push_locales = %w[de-DE pt-BR es-ES fr-FR it ja]
    key = api_key
    metadata_dir = File.expand_path("metadata/ios", __dir__)
    push_dir = File.expand_path("metadata/ios_release_notes_push", __dir__)
    FileUtils.rm_rf(push_dir) if Dir.exist?(push_dir)
    FileUtils.mkdir_p(push_dir)

    # Primary ASC release notes live in the real en-GB locale folder.
    en_gb_release_notes = File.join(metadata_dir, "en-GB", "release_notes.txt")
    UI.user_error!("Missing #{en_gb_release_notes}") unless File.exist?(en_gb_release_notes)
    en_gb_dst = File.join(push_dir, "en-GB")
    FileUtils.mkdir_p(en_gb_dst)
    FileUtils.cp(en_gb_release_notes, File.join(en_gb_dst, "release_notes.txt"))

    ios_push_locales.each do |locale|
      src = File.join(metadata_dir, locale, "release_notes.txt")
      next unless File.exist?(src)

      locale_dir = File.join(push_dir, locale)
      FileUtils.mkdir_p(locale_dir)
      FileUtils.cp(src, File.join(locale_dir, "release_notes.txt"))
    end

    begin
      deliver(
        api_key: key,
        skip_metadata: false,
        skip_binary_upload: true,
        skip_screenshots: true,
        force: true,
        submit_for_review: false,
        automatic_release: false,
        phased_release: false,
        reject_if_possible: false,
        overwrite_screenshots: false,
        metadata_path: push_dir,
        ignore_language_directory_validation: true,
        run_precheck_before_submit: false
      )
    ensure
      FileUtils.rm_rf(push_dir) if Dir.exist?(push_dir)
    end
  end

  ################################################################
  # Push screenshots only to App Store Connect
  ################################################################
  desc "Push screenshots to App Store Connect (no metadata, no binary)"
  lane :screenshot_push do
    check_ios_creds
    screenshots_path = stage_ios_screenshots_upload
    replace_ios_screenshots(screenshots_path)
  end
end

platform :android do
  ################################################################
  # Check Android credentials and connectivity
  ################################################################
  desc "Verify Android credentials and Google Play connectivity"
  lane :metadata_check do
    check_android_creds
    UI.message "Checking Play Console connectivity (validate_only)..."
    supply(
      package_name: "com.threed_print_calculator",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
      metadata_path: "fastlane/metadata/android",
      validate_only: true
    )
    UI.success "Android credentials and connectivity OK"
  end

  ################################################################
  # Pull current metadata from Google Play to local files
  #
  # NOTE: `supply` does not support download. Use the Google Play
  # Console web UI to export/store listings manually when needed.
  # This lane exists as a no-op placeholder for future tooling.
  # See: https://github.com/fastlane/fastlane/tree/master/supply
  ################################################################
  desc "Pull Android metadata from Google Play Console"
  lane :metadata_pull do
    check_android_creds
    UI.important "supply has no download mode — this is a no-op"
    UI.important "Export listing from Google Play Console web UI manually"
    UI.important "Manage > App presence > Store listing, then copy content"
    UI.message "Android pull: no action taken"
  end

  ################################################################
  # Push local metadata changes to Google Play
  ################################################################
  desc "Push metadata to Google Play Console (no APK)"
  lane :metadata_push do |options|
    check_android_creds
    track = options[:track] || ENV["METADATA_TRACK"] || "open_testing"
    track = "beta" if %w[open_testing open-testing open testing].include?(track.to_s.downcase.tr(" ", "_"))
    version_code = options[:version_code] || ENV["VERSION_CODE"]

    if version_code.to_s.strip.empty?
      version_codes = google_play_track_version_codes(
        package_name: "com.threed_print_calculator",
        track: track
      )
      version_code = version_codes.compact.max
    end

    UI.user_error!("version_code is required") if version_code.to_s.strip.empty?

    check_no_untranslated(
      File.expand_path("metadata/android", __dir__),
      %w[en-GB de-DE pt-BR es-ES fr-FR it-IT ja-JP],
      %w[title.txt short_description.txt full_description.txt changelogs/default.txt]
    )
    supply(
      package_name: "com.threed_print_calculator",
      track: track,
      version_code: version_code,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
      metadata_path: "fastlane/metadata/android"
    )
  end

  ################################################################
  # Push changelogs only to Google Play
  #
  # Useful for patch releases where listing copy stays unchanged and
  # only What's New text needs updating for an existing version code.
  ################################################################
  desc "Push Android changelogs only to Google Play Console (no APK)"
  lane :changelog_push do |options|
    check_android_creds
    track = options[:track] || ENV["METADATA_TRACK"] || "open_testing"
    track = "beta" if %w[open_testing open-testing open testing].include?(track.to_s.downcase.tr(" ", "_"))
    version_code = options[:version_code] || ENV["VERSION_CODE"]

    if version_code.to_s.strip.empty?
      version_codes = google_play_track_version_codes(
        package_name: "com.threed_print_calculator",
        track: track
      )
      version_code = version_codes.compact.max
    end

    UI.user_error!("version_code is required") if version_code.to_s.strip.empty?

    check_no_untranslated(
      File.expand_path("metadata/android", __dir__),
      %w[en-GB de-DE pt-BR es-ES fr-FR it-IT ja-JP],
      %w[changelogs/default.txt]
    )

    supply(
      package_name: "com.threed_print_calculator",
      track: track,
      version_code: version_code,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
      metadata_path: "fastlane/metadata/android"
    )
  end

  ################################################################
  # Push screenshots only to Google Play
  ################################################################
  desc "Push screenshots to Google Play Console (no metadata, no APK)"
  lane :screenshot_push do
    check_android_creds
    staging_dir = stage_android_screenshots_upload

    begin
      supply(
        package_name: "com.threed_print_calculator",
        skip_upload_apk: true,
        skip_upload_aab: true,
        skip_upload_metadata: true,
        skip_upload_images: true,
        skip_upload_screenshots: false,
        skip_upload_changelogs: true,
        metadata_path: staging_dir,
        sync_image_upload: true
      )
    ensure
      FileUtils.rm_rf(staging_dir) if Dir.exist?(staging_dir)
    end
  end
end

################################################################
# Helpers
################################################################

# Check for TODO TRANSLATE markers in locale metadata files.
# Exits lane if any are found.
def check_no_untranslated(metadata_dir, locales, files)
  issues = []
  locales.each do |locale|
    files.each do |f|
      path = File.join(metadata_dir, locale, f)
      if !File.exist?(path)
        issues << "MISSING: #{path}"
      elsif File.read(path).include?("TODO TRANSLATE:")
        issues << "UNTRANSLATED: #{path}"
      end
    end
  end
  unless issues.empty?
    issues.each { |msg| UI.error(msg) }
    UI.user_error!("Untranslated metadata found — fix TODO TRANSLATE markers before pushing")
  end
  UI.success "All metadata present and translated"
end

################################################################
# Shared lanes
################################################################
desc "Pull metadata from both App Store Connect and Google Play"
lane :metadata_pull_all do
  sh("bundle", "exec", "fastlane", "ios", "metadata_pull")
  sh("bundle", "exec", "fastlane", "android", "metadata_pull")
end

desc "Check credentials and connectivity for both stores"
lane :metadata_check_all do
  sh("bundle", "exec", "fastlane", "ios", "metadata_check")
  sh("bundle", "exec", "fastlane", "android", "metadata_check")
end

desc "Push metadata to both stores"
lane :metadata_push_all do
  sh("bundle", "exec", "fastlane", "ios", "metadata_push")
  sh("bundle", "exec", "fastlane", "android", "metadata_push")
end

desc "Push screenshots to both stores"
lane :screenshot_push_all do
  sh("bundle", "exec", "fastlane", "ios", "screenshot_push")
  sh("bundle", "exec", "fastlane", "android", "screenshot_push")
end
