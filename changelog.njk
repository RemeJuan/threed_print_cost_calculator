<h1>Changelog</h1>
<article id="changelog-content" class="markdown-content" aria-live="polite">
  <p>Loading changelog…</p>
</article>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
  const changelogContent = document.getElementById("changelog-content");
  const CHANGELOG_URLS = [
    "https://raw.githubusercontent.com/RemeJuan/threed_print_cost_calculator/main/CHANGELOG.md",
    "https://cdn.jsdelivr.net/gh/RemeJuan/threed_print_cost_calculator@main/CHANGELOG.md"
  ];

  const fetchFirstAvailableChangelog = async () => {
    for (const url of CHANGELOG_URLS) {
      try {
        const response = await fetch(url, { cache: "no-store" });
        if (response.ok) {
          return await response.text();
        }
      } catch (error) {
        // Try the next source.
      }
    }

    throw new Error("Failed to fetch changelog from all configured sources.");
  };

  const loadChangelog = async () => {
    if (!changelogContent) {
      return;
    }

    try {
      const markdown = await fetchFirstAvailableChangelog();
      changelogContent.innerHTML = marked.parse(markdown);

      changelogContent.querySelectorAll("a").forEach((link) => {
        const span = document.createElement("span");
        span.textContent = link.textContent || "";
        link.replaceWith(span);
      });
    } catch (error) {
      changelogContent.innerHTML = "";
      const message = document.createElement("p");
      message.textContent = "Unable to load changelog content right now.";
      const details = document.createElement("p");
      details.className = "markdown-error";
      details.textContent = error instanceof Error ? error.message : "Unknown error";
      changelogContent.append(message, details);
    }
  };

  loadChangelog();
</script>
